    x = -x//1
    return int(-x)
def calc():
    firstnumber = 0.0
    operator = ' '
    secondnumber = 0.0
    output = 0.0
    firstnumber = input("inputnumber1:")
    operator = input("operator[+, -, /, *]:")
    secondnumber = input("inputnumber2:")
